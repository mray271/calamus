#compdef calamus
# zsh completion for calamus
# Install to: /usr/share/zsh/site-functions/_calamus

_calamus() {
    _arguments \
        '(-p --preview)'{-p,--preview}'[open in read-only preview mode]' \
        '--pipe-base-path=[base path for resolving relative links in piped input]:path:_files' \
        '--help[show help options]' \
        '--help-all[show all help options]' \
        '--help-gapplication[show GApplication options]' \
        '*:markdown file:_files -g "*.md"'
}

_calamus
